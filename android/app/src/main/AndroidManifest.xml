<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Required for Android's built-in screen recording (MediaProjection).
         This only captures pixels already shown on screen while the user
         manually browses their own logged-in store app; the app never
         requests network/account access to Zepto/Blinkit/Instamart/BigBasket. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Local-only storage of recorded frames/prices; no internet permission
         is declared because this app has no network functionality. -->

    <application
        android:label="Smart Grocery Assistant"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme" />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- The flutter_screen_recording plugin declares its own foreground
             service in its bundled manifest; Gradle's manifest merger pulls
             it in automatically, so it isn't (and shouldn't be) hand-listed
             here. -->

        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
</manifest>
